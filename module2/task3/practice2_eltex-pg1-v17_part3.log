# 1. Регистрация на GitHub выполнена
# 2. Настройка git: user.name, user.email, defaultBranch
# 3. Установлены git и gh
# 4. Создание SSH ключа для GitHub
ssh-keygen -t ed25519 -f ~/.ssh/hyrtgef -C "hyrtgef"
# Публичный ключ создан
# 5. Подключение к GitHub через gh auth login
gh auth login
# Выбрано: GitHub.com, SSH, ключ ~/.ssh/hyrtgef.pub
# 6. Настройка автоматической авторизации
gh auth setup-git --hostname github.com
# 7. Проверка статуса авторизации
gh auth status
# 8. Создание репозитория на GitHub
gh repo create --public practice2_hyrtgef
# Репозиторий создан: https://github.com/hyrtgef/practice2_hyrtgef
# 9. Наполнение репозитория
mkdir ~/practice2_hyrtgef && cd ~/practice2_hyrtgef
echo "# Практика 2" >> README.md
git init
git add README.md
git commit -m "first commit"
git branch -M main
git remote add origin https://github.com/hyrtgef/practice2_hyrtgef.git
git status
git push -u origin main
mkdir -p module1/task1 module1/task2 module1/task3
ls -la module1/
# 10. Клонирование репозитория
mkdir ~/practice2_hyrtgef_clone && cd ~/practice2_hyrtgef_clone
git clone https://github.com/hyrtgef/practice2_hyrtgef.git .
ls -la
# 11. Внесение изменений и синхронизация
cd ~/practice2_hyrtgef
echo "Обновление от $(date)" >> README.md
git add README.md
git commit -m "update README with date"
git push
cd ~/practice2_hyrtgef_clone
git fetch
git log origin/main -3
git diff main origin/main
git pull
